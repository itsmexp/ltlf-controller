{
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "search.exclude": {
    "**/__pycache__": true
  },
  "files.watcherExclude": {
    "**/__pycache__/**": true
  },
  "python.analysis.extraPaths": [
    "${workspaceFolder}/.venv/lib/python3.12/site-packages",
    "/usr/lib/python3/dist-packages"
  ]
}

